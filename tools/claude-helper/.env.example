# Copia este archivo a .env y rellena tu API key.
# .env esta ignorado por git (ver .gitignore) — NUNCA lo subas al repo.

# Obligatorio: tu API key de https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opcional: modelo a usar.
#   claude-opus-4-8   -> maxima capacidad (por defecto)
#   claude-sonnet-5   -> mas barato, muy bueno para pruebas rutinarias
#   claude-haiku-4-5  -> el mas barato/rapido para tareas simples
OREL_AI_MODEL=claude-opus-4-8

# Opcional: tope de tokens de salida por respuesta.
OREL_AI_MAX_TOKENS=8000
